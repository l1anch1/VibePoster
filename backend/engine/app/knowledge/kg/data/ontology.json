{
  "$schema": "design_ontology_v3",
  "$version": "3.0.0",
  "$description": "五层设计知识本体 — 显式语义三元组 + 多跳推理链",

  "nodes": {

    "emotions": {
      "Trust": {
        "description": "可靠、稳定、专业的信任感",
        "palettes": {
          "primary": ["#0066CC", "#1E3A5F", "#2C5282"],
          "accent": ["#48BB78", "#38B2AC"]
        }
      },
      "Innovation": {
        "description": "前沿、突破、科技感",
        "palettes": {
          "primary": ["#6366F1", "#8B5CF6", "#0EA5E9"],
          "accent": ["#22D3EE", "#A855F7"],
          "gradient": ["linear-gradient(135deg, #667eea 0%, #764ba2 100%)"]
        }
      },
      "Excitement": {
        "description": "活力、热情、行动力",
        "palettes": {
          "primary": ["#EF4444", "#F97316", "#FBBF24"],
          "accent": ["#EC4899", "#F43F5E"]
        }
      },
      "Premium": {
        "description": "奢华、高端、独特品位",
        "palettes": {
          "primary": ["#1A1A1A", "#2D2D2D", "#0F0F0F"],
          "accent": ["#D4AF37", "#C9A962", "#B8860B"],
          "metallic": ["#FFD700", "#C0C0C0", "#E8D5B7"]
        }
      },
      "Warmth": {
        "description": "温暖、亲切、自然",
        "palettes": {
          "primary": ["#D97706", "#B45309", "#92400E"],
          "accent": ["#059669", "#10B981"],
          "natural": ["#F5F0E6", "#E7DDD0", "#D4C4A8"]
        }
      },
      "Freshness": {
        "description": "新鲜、健康、活力",
        "palettes": {
          "primary": ["#22C55E", "#16A34A", "#15803D"],
          "accent": ["#FBBF24", "#F59E0B"],
          "fresh": ["#ECFDF5", "#D1FAE5", "#A7F3D0"]
        }
      },
      "Playfulness": {
        "description": "趣味、童趣、创意",
        "palettes": {
          "primary": ["#EC4899", "#8B5CF6", "#06B6D4"],
          "accent": ["#FBBF24", "#22C55E", "#F43F5E"],
          "pop": ["#FF6B6B", "#4ECDC4", "#FFE66D"]
        }
      },
      "Serenity": {
        "description": "宁静、平和、冥想感",
        "palettes": {
          "primary": ["#818CF8", "#6366F1", "#4F46E5"],
          "accent": ["#C7D2FE", "#A5B4FC"],
          "muted": ["#F5F3FF", "#EDE9FE", "#DDD6FE"]
        }
      },
      "Urgency": {
        "description": "紧迫感、促销、即刻行动",
        "palettes": {
          "primary": ["#DC2626", "#B91C1C", "#991B1B"],
          "accent": ["#FBBF24", "#F59E0B", "#D97706"],
          "alert": ["#FEF3C7", "#FDE68A"]
        }
      }
    },

    "industries": {
      "Tech": {
        "description": "科技、互联网、软件行业",
        "design_principles": ["Clean interfaces", "Data visualization friendly", "Scalable design system"],
        "avoid": ["Overly decorative", "Warm earth tones", "Script fonts"]
      },
      "Food": {
        "description": "餐饮、食品、饮料行业",
        "design_principles": ["Appetite appeal", "High-quality food photography", "Sensory engagement"],
        "avoid": ["Cold blue tones", "Sterile layouts", "Technical fonts"]
      },
      "Luxury": {
        "description": "奢侈品、高端消费、时尚行业",
        "design_principles": ["Less is more", "Quality over quantity", "Timeless aesthetics"],
        "avoid": ["Bright neon colors", "Cluttered layouts", "Casual fonts"]
      },
      "Healthcare": {
        "description": "医疗、健康、制药行业",
        "design_principles": ["Clear information hierarchy", "Accessible design", "Professional credibility"],
        "avoid": ["Aggressive colors", "Complex patterns", "Decorative fonts"]
      },
      "Education": {
        "description": "教育、培训、知识服务",
        "design_principles": ["Easy to read", "Engaging visuals", "Clear structure"],
        "avoid": ["Monotonous layouts", "Small text", "Distracting elements"]
      },
      "Entertainment": {
        "description": "娱乐、游戏、媒体行业",
        "design_principles": ["High visual impact", "Immersive experience", "Bold statements"],
        "avoid": ["Conservative colors", "Static layouts", "Formal typography"]
      },
      "Finance": {
        "description": "金融、银行、投资行业",
        "design_principles": ["Clear data presentation", "Authority signaling", "Precise typography"],
        "avoid": ["Playful fonts", "Neon colors", "Casual layouts"]
      },
      "Beauty": {
        "description": "美妆、个护、护肤行业",
        "design_principles": ["Sensory appeal", "Elegant whitespace", "Premium color palettes"],
        "avoid": ["Heavy technical layouts", "Dark cluttered backgrounds", "Rigid grid structures"]
      }
    },

    "vibes": {
      "Minimalist": {
        "description": "极简主义风格",
        "modifiers": { "whitespace": "generous", "elements": "essential-only", "color_count": "1-2" }
      },
      "Energetic": {
        "description": "充满活力的风格",
        "modifiers": { "whitespace": "minimal", "elements": "abundant", "color_count": "3-5" }
      },
      "Professional": {
        "description": "专业商务风格",
        "modifiers": { "whitespace": "balanced", "elements": "structured", "color_count": "2-3" }
      },
      "Friendly": {
        "description": "亲切友好风格",
        "modifiers": { "whitespace": "comfortable", "elements": "rounded", "color_count": "3-4" }
      },
      "Bold": {
        "description": "大胆醒目风格",
        "modifiers": { "whitespace": "strategic", "elements": "oversized", "color_count": "2-4" }
      },
      "Retro": {
        "description": "复古怀旧风格",
        "modifiers": { "whitespace": "moderate", "elements": "vintage-styled", "color_count": "3-4" }
      },
      "Futuristic": {
        "description": "未来科技风格",
        "modifiers": { "whitespace": "strategic", "elements": "high-tech", "color_count": "2-4" }
      }
    },

    "color_strategies": {
      "Monochromatic": {
        "description": "单色系配色",
        "method": "使用同一色相的不同明度和饱和度",
        "effect": "统一、和谐、专业"
      },
      "Complementary": {
        "description": "互补色配色",
        "method": "使用色轮上相对的两种颜色",
        "effect": "对比强烈、视觉冲击、活力"
      },
      "Analogous": {
        "description": "类似色配色",
        "method": "使用色轮上相邻的颜色",
        "effect": "和谐、自然、舒适"
      },
      "Triadic": {
        "description": "三色配色",
        "method": "使用色轮上等距的三种颜色",
        "effect": "丰富、平衡、创意"
      },
      "Split-Complementary": {
        "description": "分裂互补色配色",
        "method": "一种颜色加其互补色两侧的颜色",
        "effect": "对比但不冲突、现代感"
      },
      "Neutral-with-Accent": {
        "description": "中性色加强调色",
        "method": "大面积中性色搭配少量亮眼强调色",
        "effect": "高端、克制、聚焦"
      },
      "High-Contrast": {
        "description": "高对比配色",
        "method": "使用明度或色相差异极大的颜色组合",
        "effect": "醒目、紧迫、视觉张力"
      },
      "Earth-tones": {
        "description": "大地色系配色",
        "method": "使用棕、米、橄榄绿等自然色",
        "effect": "自然、温暖、朴实"
      },
      "Nature-inspired": {
        "description": "自然灵感配色",
        "method": "取自植物、天空、水等自然场景的色彩",
        "effect": "清新、健康、生机"
      },
      "Multi-color": {
        "description": "多色配色",
        "method": "同时使用四种及以上高饱和度颜色",
        "effect": "欢快、童趣、丰富"
      },
      "High-saturation": {
        "description": "高饱和度配色",
        "method": "所有颜色均保持高彩度",
        "effect": "夺目、活泼、年轻化"
      }
    },

    "typography_styles": {
      "Sans-Serif": {
        "description": "无衬线字体，现代清晰",
        "family_hints": ["Inter", "Helvetica Neue", "Source Han Sans"]
      },
      "Serif": {
        "description": "衬线字体，经典优雅",
        "family_hints": ["Playfair Display", "Source Han Serif", "Noto Serif"]
      },
      "Display": {
        "description": "展示型字体，强视觉冲击",
        "family_hints": ["Impact", "Anton", "Black Han Sans"]
      },
      "Rounded-Sans": {
        "description": "圆体无衬线，亲切友好",
        "family_hints": ["Nunito", "Varela Round", "LXGW WenKai"]
      },
      "Handwriting": {
        "description": "手写体，个性自然",
        "family_hints": ["Dancing Script", "Caveat", "ZCOOL XiaoWei"]
      }
    },

    "layout_patterns": {
      "Grid": {
        "description": "网格布局，元素按行列对齐",
        "strategy": "Structured",
        "intent": "Stability",
        "patterns": ["Grid", "Symmetrical"],
        "effect": "可靠、专业、有序"
      },
      "Centered": {
        "description": "居中布局，视线聚焦于中心",
        "strategy": "Balanced",
        "intent": "Focus",
        "patterns": ["Centered"],
        "effect": "平衡、庄重、聚焦"
      },
      "Diagonal": {
        "description": "对角线布局，产生动感张力",
        "strategy": "Dynamic",
        "intent": "Forward-thinking",
        "patterns": ["Diagonal"],
        "effect": "活力、现代、前瞻"
      },
      "Asymmetric": {
        "description": "不对称布局，打破常规引发关注",
        "strategy": "Dynamic",
        "intent": "Disruption",
        "patterns": ["Asymmetric"],
        "effect": "创新、个性、吸引力"
      },
      "Layered": {
        "description": "层叠布局，通过前后景创造深度",
        "strategy": "Dynamic",
        "intent": "Depth",
        "patterns": ["Layered", "Overlapping"],
        "effect": "丰富、立体、沉浸"
      },
      "Burst": {
        "description": "放射布局，从中心向外扩散",
        "strategy": "Energetic",
        "intent": "Impact",
        "patterns": ["Burst"],
        "effect": "爆发力、注意力捕获"
      },
      "GoldenRatio": {
        "description": "黄金比例布局，经典美学分割",
        "strategy": "Minimal",
        "intent": "Sophistication",
        "patterns": ["Golden-ratio", "Generous-whitespace"],
        "effect": "高端、优雅、比例和谐"
      },
      "Flowing": {
        "description": "流动曲线布局，自然有机形态",
        "strategy": "Organic",
        "intent": "Comfort",
        "patterns": ["Curved", "Flowing", "Natural-hierarchy"],
        "effect": "自然、亲切、引导视线"
      },
      "ZPattern": {
        "description": "Z 形阅读路径布局，引导快速扫描",
        "strategy": "Guided",
        "intent": "Conversion",
        "patterns": ["Z-pattern", "Visual-hierarchy"],
        "effect": "高转化、易扫描、信息明确"
      },
      "Scattered": {
        "description": "散落式布局，随机感强",
        "strategy": "Playful",
        "intent": "Engagement",
        "patterns": ["Scattered", "Irregular-grid"],
        "effect": "趣味、探索感、年轻"
      },
      "WhitespaceRich": {
        "description": "留白丰富布局，极简呼吸感",
        "strategy": "Clean",
        "intent": "Clarity",
        "patterns": ["Whitespace-rich", "Balanced"],
        "effect": "清爽、健康、通透"
      }
    },

    "decoration_themes": {
      "SolidClean": {
        "description": "纯色简洁装饰，适合信任感与专业场景",
        "divider":  { "style": "solid",    "color_source": "accent",  "thickness": 3, "opacity": 0.7  },
        "overlay":  { "type": "solid",     "direction": "to-bottom",  "color_source": "primary", "opacity": 0.6  },
        "shape":    { "border_radius": 0,  "fill_source": "accent",   "border_width": 0, "border_color_source": "primary", "opacity": 0.9 }
      },
      "GradientModern": {
        "description": "渐变现代装饰，适合科技创新场景",
        "divider":  { "style": "gradient",       "color_source": "gradient", "thickness": 3, "opacity": 0.8  },
        "overlay":  { "type": "linear-gradient",  "direction": "diagonal",   "color_source": "primary", "opacity": 0.7  },
        "shape":    { "border_radius": 8,  "fill_source": "accent",   "border_width": 0, "border_color_source": "primary", "opacity": 0.9 }
      },
      "DashedEnergetic": {
        "description": "虚线活力装饰，适合动感促销场景",
        "divider":  { "style": "dashed",          "color_source": "accent",  "thickness": 4, "opacity": 1.0  },
        "overlay":  { "type": "radial-gradient",  "direction": "to-bottom",  "color_source": "primary", "opacity": 0.6  },
        "shape":    { "border_radius": 0,  "fill_source": "accent",   "border_width": 0, "border_color_source": "primary", "opacity": 0.9 }
      },
      "SubtleElegant": {
        "description": "细腻优雅装饰，适合高端奢华场景",
        "divider":  { "style": "solid",           "color_source": "accent",  "thickness": 2, "opacity": 0.5  },
        "overlay":  { "type": "linear-gradient",  "direction": "to-bottom",  "color_source": "primary", "opacity": 0.8  },
        "shape":    { "border_radius": 4,  "fill_source": "primary",  "border_width": 1, "border_color_source": "accent", "opacity": 0.9 }
      },
      "DottedOrganic": {
        "description": "点状有机装饰，适合温暖亲切场景",
        "divider":  { "style": "dotted",   "color_source": "accent",  "thickness": 3, "opacity": 0.7  },
        "overlay":  { "type": "solid",     "direction": "to-bottom",  "color_source": "natural", "opacity": 0.6  },
        "shape":    { "border_radius": 20, "fill_source": "natural",  "border_width": 0, "border_color_source": "accent", "opacity": 0.9 }
      },
      "PlayfulBold": {
        "description": "趣味大胆装饰，适合童趣创意场景",
        "divider":  { "style": "dashed",          "color_source": "pop",     "thickness": 4, "opacity": 0.9  },
        "overlay":  { "type": "radial-gradient",  "direction": "to-bottom",  "color_source": "pop",     "opacity": 0.5  },
        "shape":    { "border_radius": 24, "fill_source": "pop",      "border_width": 0, "border_color_source": "accent", "opacity": 0.9 }
      }
    }
  },

